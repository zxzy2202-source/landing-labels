JWT_SECRET=replace-with-a-long-random-secret

# Production database for Vercel. Local development falls back to file:local.db.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Admin bootstrap script defaults to admin/admin123456 if unset.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-a-strong-password

# Optional lead notifications.
SERVERCHAN_SENDKEY=
RESEND_API_KEY=
NOTIFICATION_EMAIL=Sales@zxpapers.com

# Optional Cloudflare R2 media storage. Recommended for Vercel uploads.
# Production uploads happen in the server-side admin media API route, so these
# variables must be configured in Vercel for the deployed site. Add the same
# values to local .env only if you also want local admin uploads to go to R2.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=landing-labels
# Public asset base URL, for example a custom domain or the R2 public bucket URL.
# Do not use the Cloudflare catalog/dashboard URL here.
NEXT_PUBLIC_R2_URL=
